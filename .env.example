# Railway private network (RabbitMQ service named "RabbitMQ"):
RABBITMQ_URL=amqp://${{RabbitMQ.RABBITMQ_DEFAULT_USER}}:${{RabbitMQ.RABBITMQ_DEFAULT_PASS}}@${{RabbitMQ.RAILWAY_PRIVATE_DOMAIN}}:5672/${{RabbitMQ.RABBITMQ_DEFAULT_VHOST}}

# Or set a full AMQP URL directly:
# RABBITMQ_URL=amqp://user:pass@rabbitmq.railway.internal:5672/
# AMQP_URL=amqp://guest:guest@localhost:5672/

# BTC 1h source of truth (polled each hour)
FEED_SYMBOL=BTCUSDT
FEED_TIMEFRAME=1h
FEED_LOOKBACK_DAYS=420
FEED_MARKET=futures
FEED_WITH_METRICS=1
FEED_WITH_FUNDING=1
FEED_POLL_SECONDS=3600
FEED_CACHE_DIR=/tmp/feed-cache

# Embedded in each RabbitMQ event
FEED_PUBLISH_BAR_COUNT=400
FEED_PUBLISH_DAILY_BAR_COUNT=400
# RUN_ONCE=0
