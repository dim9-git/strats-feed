KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# BTC 1h source of truth (polled each hour)
FEED_SYMBOL=BTCUSDT
FEED_TIMEFRAME=1h
FEED_LOOKBACK_DAYS=420
FEED_MARKET=futures
FEED_WITH_METRICS=1
FEED_WITH_FUNDING=1
FEED_POLL_SECONDS=3600
FEED_CACHE_DIR=/tmp/feed-cache

# Embedded in each Kafka event
FEED_PUBLISH_BAR_COUNT=400
FEED_PUBLISH_DAILY_BAR_COUNT=400
# RUN_ONCE=0
