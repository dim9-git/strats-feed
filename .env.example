# Same Railway private network as Kafka:
KAFKA_BOOTSTRAP_SERVERS=kafka.railway.internal:9092
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=kafka
KAFKA_SASL_PASSWORD=

# Or reference the Kafka service vars:
# KAFKA_BOOTSTRAP_SERVERS=${{Kafka.KAFKA_INTERNAL_URL}}
# KAFKA_SASL_PASSWORD=${{Kafka.KAFKA_PASSWORD}}

# External / public TCP proxy (if needed):
# KAFKA_BOOTSTRAP_SERVERS=${{Kafka.KAFKA_URL}}
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SSL_VERIFY=0

# BTC 1h source of truth (polled each hour)
FEED_SYMBOL=BTCUSDT
FEED_TIMEFRAME=1h
FEED_LOOKBACK_DAYS=420
FEED_MARKET=futures
FEED_WITH_METRICS=1
FEED_WITH_FUNDING=1
FEED_POLL_SECONDS=3600
FEED_CACHE_DIR=/tmp/feed-cache

# Embedded in each Kafka event
FEED_PUBLISH_BAR_COUNT=400
FEED_PUBLISH_DAILY_BAR_COUNT=400
# RUN_ONCE=0
